# Registry público fixado no projeto: sem isso, um npm install rodado na rede
# do trabalho (Nexus portal.pje.redejt) grava URLs internas no package-lock e
# o npm ci da Vercel nunca consegue baixar nada (ENOTFOUND fora da VPN).
registry=https://registry.npmjs.org/
audit=false
fund=false
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
